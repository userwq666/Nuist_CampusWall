@base = {{host}}/api
@token = {{token}}
@myPostId = 1

### 1) 发帖成功（预期 code=0）
POST {{base}}/post/create
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "第一条帖子",
  "content": "这是帖子正文",
  "imageUrl": null
}

### 2) 发帖失败（不带 token，预期 code=406）
POST {{base}}/post/create
Content-Type: application/json

{
  "title": "未登录发帖",
  "content": "这条应该失败",
  "imageUrl": null
}

### 3) 发帖失败（标题为空，预期 code=422）
POST {{base}}/post/create
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "",
  "content": "标题为空应触发参数校验",
  "imageUrl": null
}

### 4) 公开帖子分页（预期 code=0）
GET {{base}}/post/page?pageNum=1&pageSize=5
Authorization: Bearer {{token}}

### 5) 我的帖子分页（预期 code=0）
GET {{base}}/post/my/page?pageNum=1&pageSize=5
Authorization: Bearer {{token}}

### 6) 帖子详情成功（预期 code=0）
GET {{base}}/post/{{myPostId}}
Authorization: Bearer {{token}}

### 7) 修改我的帖子成功（预期 code=0）
POST {{base}}/post/update/{{myPostId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "修改后的标题",
  "content": "修改后的正文",
  "imageUrl": null
}

### 8) 修改帖子参数非法（预期 code=422）
POST {{base}}/post/update/{{myPostId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "",
  "content": "",
  "imageUrl": null
}

### 9) 修改不存在帖子（预期 code=409）
POST {{base}}/post/update/999999
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "不存在帖子",
  "content": "不存在帖子",
  "imageUrl": null
}

### 10) 删除我的帖子成功（预期 code=0）
POST {{base}}/post/delete/{{myPostId}}
Authorization: Bearer {{token}}

### 11) 删除不存在帖子（预期 code=409）
POST {{base}}/post/delete/999999
Authorization: Bearer {{token}}

### 12) 删除他人帖子（预期 code=412，需准备他人帖子ID）
POST {{base}}/post/delete/3
Authorization: Bearer {{token}}
